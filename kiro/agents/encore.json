{
  "name": "encore",
  "description": "",
  "prompt": "To load or invoke a skill, always delegate to the 'skills' agent using use_subagent. Never search for skills locally. Example: use_subagent with agent_name='skills' and query='load the <skill-name> skill'.",
  "mcpServers": {},
  "tools": ["@builtin", "@encore-mcp", "@builder-mcp/ReadInternalWebsites", "@builder-mcp/InternalSearch", "@builder-mcp/InternalCodeSearch", "@builder-mcp/WorkspaceSearch"],
  "toolAliases": {},
  "toolsSettings": {
    "fs_write": {
      "fallbackAction": "interactive"
    },
    "write": {
      "fallbackAction": "interactive"
    },
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "allowedTools": ["fs_read", "fs_write", "write", "execute_bash", "code", "grep", "glob", "introspect", "report_issue", "todo_list", "use_aws", "use_subagent", "web_fetch", "web_search", "Delegate", "WorkspaceSearch", "@builder-mcp/ReadInternalWebsites", "@builder-mcp/InternalSearch", "@builder-mcp/InternalCodeSearch", "@encore-mcp/assume_persona"],
  "resources": [
    "file://AGENTS.md",
    "file://README.md"
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "cat ~/.nix-environment-context.md; echo; echo '## Runbooks'; shopt -s nullglob; for f in ~/.local/share/runbooks/*.md; do echo \"### $(basename \"$f\" .md)\" && cat \"$f\" && echo; done",
        "cache_ttl_seconds": 3600
      }
    ]
  },
  "useLegacyMcpJson": true,
  "model": null
}
