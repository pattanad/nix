  "hooks": {
    "agentSpawn": [
      {
        "command": "cat ~/.nix-environment-context.md; echo; echo '## Runbooks'; for f in ~/.local/share/runbooks/*.md; do [ -f \"$f\" ] && echo \"### $(basename \"$f\" .md)\" && cat \"$f\" && echo; done",
        "cache_ttl_seconds": 3600
      }
    ]
  },
  "useLegacyMcpJson": true,
