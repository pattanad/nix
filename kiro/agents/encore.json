{
  "name": "encore",
  "description": "",
  "prompt": null,
  "mcpServers": {},
  "tools": [
    "*"
  ],
  "toolAliases": {},
  "toolsSettings": {
    "fs_write": {
      "fallbackAction": "interactive"
    },
    "write": {
      "fallbackAction": "interactive"
    }
  },
  "allowedTools": ["fs_read", "grep", "glob", "introspect", "report_issue", "todo_list", "use_aws", "use_subagent", "web_fetch", "web_search", "Delegate", "WorkspaceSearch", "@builder-mcp/ReadInternalWebsites", "@builder-mcp/InternalSearch", "@builder-mcp/SkillsTool", "@builder-mcp/InternalCodeSearch", "@builder-mcp/BrazilBuildAnalyzerTool"],
